<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet — IPFS / I2P / Yggdrasil -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Bluetooth — Android 12+ -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />

    <!-- Bluetooth — Android < 12 -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- Location — requerida por Android para BLE scan -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <!-- Foreground service — mantener BLE activo en background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"/>
    <!-- Foreground service — IPFS daemon (data sync over network) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <!-- WakeLock — keep CPU alive for persistent IPFS connections -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <!-- Boot completed — restart IPFS daemon on device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- APK self-update installer -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>

    <!-- Push notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Audio recording -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <!-- QR scan of contact addresses (zxing over FFI, no GMS) -->
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- Media access — Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"/>
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/>

    <!-- Media access — Android ≤ 12 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <!-- Gallery save — Android ≤ 9 (API 29+) uses MediaStore without this -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"
        tools:replace="android:maxSdkVersion"/>

    <!-- BLE feature — no requerida, permite instalar en dispositivos sin BLE -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false"/>

    <application
        android:label="Phantom Messenger"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        android:extractNativeLibs="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Impeller disabled — the Vulkan path crashed libflutter.so during
             JNI attach on a Snapdragon 865 / Android 13 device (Retroid Pocket
             Flip2), tombstone showed null deref at FlutterJNI.performNativeAttach.
             Skia renderer is more compatible across older device drivers and
             custom ROMs. Re-enable once we confirm Impeller works on the
             affected hardware (or behind a per-device opt-in). -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />

        <!-- IPFS daemon — runs in a SEPARATE process (:ipfs) so it survives
             when the user swipes the app from recent tasks. Same technique
             used by YouTube Music, Spotify, etc. for persistent playback. -->
        <service
            android:name=".IpfsForegroundService"
            android:exported="false"
            android:process=":ipfs"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync"/>

        <!-- i2pd daemon — same survival strategy as IPFS, in its own process
             so the SAM bridge stays up while the user is in another app.
             Required for the control-plane (X3DH handshake) transport. -->
        <service
            android:name=".I2pdForegroundService"
            android:exported="false"
            android:process=":i2pd"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Message receiver — keeps the Dart isolate alive so ntfy delivers
             incoming messages and local notifications fire while backgrounded -->
        <service
            android:name=".PhantomMessagingService"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Yggdrasil router — headless (NO TUN / VpnService). Hosts the
             in-process yggdrasil-go router that dials tls:// peers over normal
             internet and exposes Send/Recv; the Dart side moves IPv6 packets
             over channels. Runs in the MAIN process (NOT :ygg): the service and
             MainActivity's send/recv channel handlers share the router instance
             via companion statics, which only works in one process. A foreground
             service keeps the process alive while backgrounded — with none of
             the system-wide-tunnel fallout the old VpnService had. -->
        <service
            android:name=".YggdrasilService"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Waku relay node — lightweight P2P messaging with store-and-forward.
             Runs in its own process (:waku) for the same survival reasons as
             IPFS, but consumes far less memory and battery since Waku is
             designed for resource-constrained mobile devices. -->
        <service
            android:name=".WakuForegroundService"
            android:exported="false"
            android:process=":waku"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Restart IPFS daemon on device boot -->
        <receiver
            android:name=".IpfsBootReceiver"
            android:exported="true"
            android:process=":ipfs">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
            </intent-filter>
        </receiver>

        <!-- Restart i2pd daemon on device boot -->
        <receiver
            android:name=".I2pdBootReceiver"
            android:exported="true"
            android:process=":i2pd">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
            </intent-filter>
        </receiver>

        <!-- FileProvider for APK installation -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileProvider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths"/>
        </provider>

    </application>
</manifest>
