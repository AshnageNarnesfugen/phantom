<?xml version="1.0" encoding="utf-8"?>
<!--
  Disable all cloud backups on Android 12+ (API 31+).
  Phantom stores private keys and messages — none of this must ever
  leave the device via Google Backup or device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="false">
        <exclude domain="root" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="."/>
    </device-transfer>
</data-extraction-rules>
